{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "Your InfluxDB data source (the one your air-monitor data is logged to)",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": true,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["air-quality", "sen5x"],
  "templating": {
    "list": [
      {
        "name": "prefix",
        "label": "Measurement prefix",
        "description": "iobroker InfluxDB path prefix. Default assumes MQTT topic 'air-monitor' on iobroker instance 0. Adjust to your setup (e.g. the part before .pm2_5.state).",
        "type": "textbox",
        "query": "mqtt.0.air-monitor.sensor",
        "current": { "text": "mqtt.0.air-monitor.sensor", "value": "mqtt.0.air-monitor.sensor" },
        "options": [
          { "text": "mqtt.0.air-monitor.sensor", "value": "mqtt.0.air-monitor.sensor", "selected": true }
        ],
        "hide": 0,
        "skipUrlSync": false
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Air Quality Monitor (SEN5x)",
  "uid": "",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "PM2.5 (fine dust)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "refId": "A", "policy": "default", "resultFormat": "time_series", "orderByTime": "ASC",
          "measurement": "${prefix}.pm2_5.state",
          "groupBy": [ { "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["none"] } ],
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "mean", "params": [] }]],
          "tags": [], "alias": "PM2.5"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "conμgm3", "decimals": 1,
          "color": { "mode": "thresholds" }, "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "green" }, { "value": 15, "color": "yellow" },
            { "value": 35, "color": "orange" }, { "value": 55, "color": "red" } ] }
        }, "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "value_and_name", "colorMode": "background",
        "graphMode": "area", "justifyMode": "auto", "showPercentChange": false, "wideLayout": true
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "PM10 (coarse dust)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "refId": "A", "policy": "default", "resultFormat": "time_series", "orderByTime": "ASC",
          "measurement": "${prefix}.pm10.state",
          "groupBy": [ { "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["none"] } ],
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "mean", "params": [] }]],
          "tags": [], "alias": "PM10"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "conμgm3", "decimals": 1,
          "color": { "mode": "thresholds" }, "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "green" }, { "value": 45, "color": "yellow" },
            { "value": 100, "color": "orange" }, { "value": 150, "color": "red" } ] }
        }, "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "value_and_name", "colorMode": "background",
        "graphMode": "area", "justifyMode": "auto", "showPercentChange": false, "wideLayout": true
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "VOC Index",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "refId": "A", "policy": "default", "resultFormat": "time_series", "orderByTime": "ASC",
          "measurement": "${prefix}.voc_index.state",
          "groupBy": [ { "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["none"] } ],
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "mean", "params": [] }]],
          "tags": [], "alias": "VOC"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none", "decimals": 0,
          "color": { "mode": "thresholds" }, "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "green" }, { "value": 150, "color": "yellow" },
            { "value": 250, "color": "orange" }, { "value": 400, "color": "red" } ] }
        }, "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "value_and_name", "colorMode": "background",
        "graphMode": "area", "justifyMode": "auto", "showPercentChange": false, "wideLayout": true
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Temperature",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "refId": "A", "policy": "default", "resultFormat": "time_series", "orderByTime": "ASC",
          "measurement": "${prefix}.temperature.state",
          "groupBy": [ { "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["none"] } ],
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "mean", "params": [] }]],
          "tags": [], "alias": "Temperature"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius", "decimals": 1,
          "color": { "mode": "thresholds" }, "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "blue" }, { "value": 10, "color": "green" },
            { "value": 30, "color": "orange" }, { "value": 40, "color": "red" } ] }
        }, "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "value_and_name", "colorMode": "value",
        "graphMode": "area", "justifyMode": "auto", "showPercentChange": false, "wideLayout": true
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Particulate Matter (PM, µg/m³)",
      "description": "Rises during printing, drops with filtering. PM2.5 = key value (orange).",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 9 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "refId": "A", "policy": "default", "resultFormat": "time_series", "orderByTime": "ASC",
          "measurement": "${prefix}.pm1_0.state",
          "groupBy": [ { "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["none"] } ],
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "mean", "params": [] }]], "tags": [], "alias": "PM1.0" },
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "refId": "B", "policy": "default", "resultFormat": "time_series", "orderByTime": "ASC",
          "measurement": "${prefix}.pm2_5.state",
          "groupBy": [ { "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["none"] } ],
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "mean", "params": [] }]], "tags": [], "alias": "PM2.5" },
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "refId": "C", "policy": "default", "resultFormat": "time_series", "orderByTime": "ASC",
          "measurement": "${prefix}.pm4_0.state",
          "groupBy": [ { "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["none"] } ],
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "mean", "params": [] }]], "tags": [], "alias": "PM4" },
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "refId": "D", "policy": "default", "resultFormat": "time_series", "orderByTime": "ASC",
          "measurement": "${prefix}.pm10.state",
          "groupBy": [ { "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["none"] } ],
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "mean", "params": [] }]], "tags": [], "alias": "PM10" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "conμgm3", "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2,
            "fillOpacity": 8, "gradientMode": "opacity", "showPoints": "never",
            "spanNulls": true, "axisPlacement": "auto", "axisLabel": "µg/m³"
          },
          "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "green" }, { "value": 35, "color": "red" } ] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "PM2.5" },
            "properties": [ { "id": "custom.lineWidth", "value": 3 }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["last", "max", "mean"] }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Gas Index (VOC + NOx)",
      "description": "VOC reacts to outgassing (ABS/ASA). Reference lines: 100 = baseline, 250 = elevated. NOx stays ~1 unless something is burning.",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 9 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "refId": "A", "policy": "default", "resultFormat": "time_series", "orderByTime": "ASC",
          "measurement": "${prefix}.voc_index.state",
          "groupBy": [ { "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["none"] } ],
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "mean", "params": [] }]], "tags": [], "alias": "VOC-Index" },
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "refId": "B", "policy": "default", "resultFormat": "time_series", "orderByTime": "ASC",
          "measurement": "${prefix}.nox_index.state",
          "groupBy": [ { "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["none"] } ],
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "mean", "params": [] }]], "tags": [], "alias": "NOx-Index" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none", "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2,
            "fillOpacity": 8, "gradientMode": "opacity", "showPoints": "never",
            "spanNulls": true, "axisLabel": "Index", "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "transparent" }, { "value": 100, "color": "blue" }, { "value": 250, "color": "orange" } ] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "VOC-Index" },
            "properties": [ { "id": "custom.lineWidth", "value": 3 }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } } ] },
          { "matcher": { "id": "byName", "options": "NOx-Index" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["last", "max", "mean"] }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Climate (Temperature + Humidity)",
      "description": "Context: room temperature drives VOC outgassing; humidity for reference.",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 7 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "targets": [
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "refId": "A", "policy": "default", "resultFormat": "time_series", "orderByTime": "ASC",
          "measurement": "${prefix}.temperature.state",
          "groupBy": [ { "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["none"] } ],
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "mean", "params": [] }]], "tags": [], "alias": "Temperature" },
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" }, "refId": "B", "policy": "default", "resultFormat": "time_series", "orderByTime": "ASC",
          "measurement": "${prefix}.humidity.state",
          "groupBy": [ { "type": "time", "params": ["$__interval"] }, { "type": "fill", "params": ["none"] } ],
          "select": [[{ "type": "field", "params": ["value"] }, { "type": "mean", "params": [] }]], "tags": [], "alias": "Humidity" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius", "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2,
            "fillOpacity": 0, "showPoints": "never", "spanNulls": true, "axisLabel": "°C"
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Temperature" },
            "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "Humidity" },
            "properties": [
              { "id": "unit", "value": "humidity" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel", "value": "% RH" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ] }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["last"] }
      }
    }
  ]
}
